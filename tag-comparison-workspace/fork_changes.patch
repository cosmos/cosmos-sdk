+	// distribute another reward once everything has vested
+	ctx = ctx.WithBlockTime(now.Add(1200 * time.Second))
+	err = testutil.FundAccount(s.bankKeeper, ctx, addr, c(stake(160)))
+	s.Require().NoError(err)
