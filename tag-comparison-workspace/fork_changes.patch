+	va = s.accountKeeper.GetAccount(ctx, addr).(*types.ClawbackVestingAccount)
+	// shouldn't be added to vesting schedule
+	s.Require().Equal(int64(4160), va.OriginalVesting.AmountOf(stakeDenom).Int64())
+}
